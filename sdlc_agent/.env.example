GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Tracing and observability
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=EVENT_ONLY

# Coder service URL (Cloud Run)
CODER_SERVICE_URL=https://coder-service-XXXXXXXXXX.us-central1.run.app

# Comma-separated list of GitHub repos to watch for PR review comments
WATCHED_REPOS=openshift-online/gcp-hcp-infra
